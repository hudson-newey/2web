{
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vsce package --no-dependencies --allow-missing-repository --skip-license -o dist/$npm_package_name-$npm_package_version.vsix"
  },
  "name": "2web",
  "displayName": "2web",
  "description": "2Web support for VSCode",
  "version": "0.0.1",
  "publisher": "hudson-newey",
  "icon": "./icons/2web.png",
  "main": "./dist/extension.js",
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "2web",
        "aliases": [
          "2Web",
          "2web"
        ],
        "extensions": [
          ".2web"
        ],
        "icon": {
          "light": "./icons/2web.svg",
          "dark": "./icons/2web.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "2web",
        "scopeName": "source.2web",
        "path": "./syntaxes/2web.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "2web",
        "path": "./snippets/2web.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
